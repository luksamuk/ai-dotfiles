{
    "$schema": "https://opencode.ai/config.json",
    "model": "ollama/glm-5.1:cloud",
    "small_model": "ollama/qwen3.5:4b",
    "default_agent": "plan",
    "username": "luksamuk",
    "autoupdate": "notify",
    "share": "manual",
    "enabled_providers": ["ollama", "opencode-zen"],
    "provider": {
        "ollama": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Ollama",
            "options": {
                "baseURL": "http://127.0.0.1:11434/v1"
            },
            "models": {
                "qwen3.5:9b": {
                    "name": "Qwen 3.5 (9B)",
                    "reasoning": true,
                    "limit": {
                        "context": 131072,
                        "output": 0
                    }
                },
                "qwen3.5:27b": {
                    "name": "Qwen 3.5 (27B)",
                    "reasoning": true,
                    "limit": {
                        "context": 131072,
                        "output": 0
                    }
                },
                "glm-5.1:cloud": {
                    "name": "GLM 5.1 (Cloud)",
                    "reasoning": true,
                    "limit": {
                        "context": 202752,
                        "output": 0
                    }
                },
                "glm-4.7-flash:cloud": {
                    "name": "GLM 4.7 Flash (Cloud)",
                    "reasoning": true,
                    "limit": {
                        "context": 202752,
                        "output": 0
                    }
                },
                "minimax-m2.5:cloud": {
                    "name": "MiniMax M2.5 (Cloud)",
                    "reasoning": true,
                    "limit": {
                        "context": 202752,
                        "output": 0
                    }
                },
		"minimax-m2.7:cloud": {
                    "name": "MiniMax M2.7 (Cloud)",
                    "reasoning": true,
                    "limit": {
                        "context": 204800,
                        "output": 0
                    }
                },
                "qwen3-coder-next:cloud": {
                    "name": "Qwen3-Coder-Next (Cloud)",
                    "reasoning": true,
                    "limit": {
                        "context": 262144,
                        "output": 0
                    }
                },
                "kimi-k2.5:cloud": {
                    "name": "Kimi K2.5 (Cloud)",
                    "reasoning": true,
                    "limit": {
                        "context": 262144,
                        "output": 0
                    }
                },
                "devstral-small-2:24b-cloud": {
                    "name": "Devstral Small 2 (24B Cloud)",
                    "reasoning": true,
                    "limit": {
                        "context": 262144,
                        "output": 0
                    }
                }
            }
        }
    },
    "mode": {
        "plan": {
            "model": "ollama/glm-5.1:cloud",
            "temperature": 0.7,
            "description": "Strategic planning and architecture decisions. Analyzes requirements, proposes solutions, and creates implementation roadmaps. Cannot modify code - only reads and plans.",
            "permission": {
                "read": "allow",
                "write": "deny",
                "edit": "deny",
                "bash": "deny"
            }
        },
        "build": {
            "model": "ollama/glm-5.1:cloud",
            "temperature": 0.3,
            "description": "Primary coding agent. Full implementation capabilities including writing, editing, and testing code. Has unrestricted access to repository and shell for development tasks.",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "bash": "allow"
            }
        },
        "research": {
            "model": "ollama/minimax-m2.7:cloud",
            "temperature": 0.7,
            "description": "Deep research and investigation agent. Explores codebases, documentation, and external sources to gather information. Can create and edit documentation files only.",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "ask",
                "bash": "deny"
            }
        },
        "brainstorm": {
            "model": "ollama/glm-5.1:cloud",
            "temperature": 1.0,
            "description": "Creative exploration and ideation agent. Generates ideas, explores alternatives, and helps with design decisions. Can edit documentation files only.",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "ask",
                "bash": "deny"
            }
        },
        "offline": {
            "model": "ollama/qwen3.5:27b",
            "temperature": 0.6,
            "description": "Offline fallback agent for when internet is unavailable. Full coding capabilities using local models. Use when cloud providers are inaccessible.",
            "steps": 25,
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "bash": "allow"
            }
        }
    }
}
