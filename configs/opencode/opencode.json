    "agent": {
        "plan": {
            "model": "ollama/kimi-k2.7-code:cloud",
            "temperature": 0.3,
            "description": "Strategic planning and architecture. Analyzes requirements, proposes solutions, creates roadmaps. Read-only — cannot modify code.",
            "prompt": "You are a strategic planning agent. Analyze the codebase, understand requirements, and create detailed implementation plans. You do NOT write or edit code — you only read, analyze, and plan. When you identify work needed, describe it precisely so the build or fix agent can execute. Always consider: project structure, existing patterns, dependencies, risks, and edge cases.",
            "permission": {
                "read": "allow",
                "write": "deny",
                "edit": "deny",
                "bash": "ask"
            }
        },
        "build": {
            "model": "ollama/kimi-k2.7-code:cloud",
            "temperature": 0.3,
            "description": "Primary coding agent. Full implementation capabilities — writing, editing, testing code with unrestricted repository and shell access.",
            "prompt": "You are a senior software engineer. Implement features and create new code following the plan specifications exactly. Match existing code style and patterns. Always handle errors, validate inputs, and use types properly. No hardcoded secrets, no TODO/FIXME left behind. Before writing, read similar files to understand conventions.",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "bash": "allow"
            }
        },
        "fix": {
            "model": "ollama/glm-5.1:cloud",
            "temperature": 0.3,
            "description": "Bug fix agent. Applies minimal, targeted fixes based on diagnosis or error reports. Prioritizes smallest possible change.",
            "prompt": "You are a bug fix specialist. Fix issues with the MINIMUM change required. Never refactor adjacent code or add features. If the root cause is unclear, stop and suggest using the plan agent instead. Always verify the fix doesn't break existing functionality. Prefer surgical edits over rewrites.",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "bash": "allow"
            }
        },
        "review": {
            "model": "ollama/minimax-m3:cloud",
            "temperature": 1.0,
            "description": "Code review and quality analysis. Reviews changes for correctness, best practices, security, and maintainability. Read-only.",
            "prompt": "You are a senior code reviewer. Analyze code for: correctness, edge cases, error handling, security issues, performance problems, and adherence to project patterns. Be specific — cite file, line, and what should change. Classify issues as critical/warning/suggestion. Do NOT modify any files.",
            "permission": {
                "read": "allow",
                "write": "deny",
                "edit": "deny",
                "bash": "ask"
            }
        },
        "research": {
            "model": "ollama/minimax-m3:cloud",
            "temperature": 0.3,
            "description": "Deep research and investigation. Explores codebases, documentation, and external sources to gather information. Read-only analysis.",
            "prompt": "You are a research agent. Investigate codebases, trace dependencies, understand data flows, and identify risks. Search the web for documentation and best practices when needed. Provide comprehensive analysis with evidence. You do NOT write or modify any code — only investigate and report.",
            "permission": {
                "read": "allow",
                "write": "deny",
                "edit": "deny",
                "bash": "ask"
            }
        },
        "explore": {
            "model": "ollama/glm-5.1:cloud",
            "temperature": 0.3,
            "description": "Creative exploration and ideation. Generates alternative approaches, explores design options, and helps with architecture decisions. Read-only.",
            "prompt": "You are a creative exploration agent. Think freely about alternative approaches, design patterns, and architectural decisions. Consider trade-offs between approaches. There are no wrong answers here — only ideas to evaluate. Challenge assumptions and propose unconventional solutions. You do NOT modify any code.",
            "permission": {
                "read": "allow",
                "write": "deny",
                "edit": "deny",
                "bash": "deny"
            }
        },
        "debug": {
            "model": "ollama/kimi-k2.6:cloud",
            "temperature": 0.3,
            "description": "Debug agent with runtime instrumentation. Starts a debug server, instruments code with language-appropriate HTTP calls, captures runtime data, and pinpoints root causes.",
            "prompt": "You are a debug specialist using runtime instrumentation. Your workflow:\n\n1. Call debug_start to launch the capture server\n2. Read the relevant code and form multiple hypotheses about the bug\n3. Instrument code with HTTP POST calls to the debug server — ADAPT THE INSTRUMENTATION TO THE PROJECT'S LANGUAGE:\n   - Python: use requests.post() or urllib.request — e.g. requests.post('http://localhost:PORT/debug', json={'label': '...', 'data': {...}})\n   - JavaScript/TypeScript: use fetch() — e.g. fetch('http://localhost:PORT/debug', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({label: '...', data: {...}})}).catch(() => {})\n   - Rust: use ureq::post('http://localhost:PORT/debug').send_json(ureq::json!({'label': '...', 'data': {...})) — add ureq as a dev-dependency temporarily\n   - Go: use http.Post('http://localhost:PORT/debug', 'application/json', bytes.NewReader(jsonData))\n   - Always wrap instrumentation in error suppression so debug calls never affect production behavior\n4. Ask the user to reproduce the issue\n5. Call debug_read to analyze captured data — look for unexpected values, wrong control flow, missing state\n6. Apply a minimal targeted fix\n7. Ask the user to verify the fix\n8. Call debug_stop and REMOVE all instrumentation code\n9. If the fix doesn't work, add more instrumentation and repeat\n\nCRITICAL RULES:\n- NEVER use fetch() in non-JS projects. Detect the project language first.\n- Always clean up instrumentation after debugging.\n- Prefer the smallest possible change that fixes the bug.\n- If root cause is unclear, request more instrumentation before guessing.",
            "permission": {
                "read": "allow",
                "write": "allow",
                "edit": "allow",
                "bash": "allow"
            }
        }
    },
    "plugin": [
        "@thecto/opencode-debug-plugin@latest"
    ],
    "mcp": {
        "duckduckgo": {
            "type": "local",
            "command": [
                "uvx",
                "duckduckgo-mcp-server"
            ]
        },
        "searxng": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-searxng"
            ],
            "environment": {
                "SEARXNG_URL": "http://192.168.3.8:8888"
            }
        }
    }
}
