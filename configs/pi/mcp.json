{
  "mcpServers": {
    "duckduckgo": {
      "command": "uvx",
      "args": [
        "duckduckgo-mcp-server"
      ],
      "lifecycle": "lazy",
      "idleTimeout": 10,
      "directTools": false
    },
    "searxng": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-searxng"
      ],
      "env": {
        "SEARXNG_URL": "http://192.168.3.8:8888"
      },
      "lifecycle": "lazy",
      "idleTimeout": 10,
      "directTools": true
    }
  }
}
