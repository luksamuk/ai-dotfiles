        "model": "north-mini-code:think",
        "enable_thinking": false
      },
      {
        "provider": "ollama",
        "model": "glm-5.2:cloud",
        "enable_thinking": true
      },
      {
        "provider": "ollama",
        "model": "kimi-k2.7-code:cloud",
        "enable_thinking": true
      },
      {
        "provider": "ollama",
        "model": "minimax-m3:cloud",
        "enable_thinking": true
      }
    ],
    "model_parameters": []
  },
  "context_servers": {
    "duckduckgo": {
      "command": "uvx",
      "args": [
        "duckduckgo-mcp-server"
      ]
    },
    "searxng": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-searxng"
      ],
      "env": {
        "SEARXNG_URL": "http://192.168.3.8:8888"
      }
    }
  },
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "base_keymap": "Emacs",
  "icon_theme": "Zed (Default)",
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Catppuccin Macchiato"
  },
