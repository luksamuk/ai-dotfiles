{
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "ui_font_family": ".ZedSans",
  "agent_buffer_font_size": 13.0,
  "agent_ui_font_size": 15.0,
  "terminal": {
    "font_size": 13.0
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^ls\\b"
            }
          ]
        }
      }
    },
    "default_model": {
      "provider": "llama-swap",
      "model": "ornith-1.0-35b:think",
      "enable_thinking": false
    },
    "favorite_models": [
      {
        "provider": "llama-swap",
        "model": "ornith-1.0-35b:think",
        "enable_thinking": false
      },
      {
        "provider": "llama-swap",
        "model": "qwen3.6-35b-a3b:think",
        "enable_thinking": false
      },
      {
