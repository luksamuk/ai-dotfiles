#!/usr/bin/env bash
# claude-local — Run Claude Code with local Qwen 3.6 35B via llama-swap
#
# Routes ALL requests through llama-swap's Anthropic-compatible /v1/messages endpoint.
# No Anthropic API key needed — everything stays local.
#
# Usage:
#   claude-local              # Interactive session
#   claude-local -p "task"    # Print mode (one-shot)
#   claude-local --resume     # Resume last session
#   claude-local --bare -p "task" --max-turns 5  # Bare mode (no plugins/hooks)
#
# Requires: llama-swap running on port 12434 with ik_llama.cpp backend
# Config: ~/.claude/settings.json — modelOverrides maps Claude Sonnet → qwen3.6-35b-a3b:think

export ANTHROPIC_BASE_URL="http://127.0.0.1:12434"
export ANTHROPIC_API_KEY="***exec claude "$@"