# API keys for OpenScience (BYOK)
# Keys go straight to the provider, never to Synthetic Sciences.
# Copy this file to .env and fill in the keys you want to use.
#
# All keys are optional — OpenScience works with free demo models too.
# At least one key enables real model access.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
# OPENAI_API_KEY=sk-...

# Google (Gemini)
# GEMINI_API_KEY=...

# DeepSeek
# DEEPSEEK_API_KEY=...

# GLM (Zhipu)
# GLM_API_KEY=...

# Kimi (Moonshot)
# KIMI_API_KEY=...