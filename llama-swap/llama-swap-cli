#!/usr/bin/env bash
# llama-swap-cli — List and inspect llama-swap models
#
# Usage:
#   llama-swap-cli list              Show configured models (aligned in TTY, TSV in pipe)
#   llama-swap-cli list --pretty     Colored + emoji output
#   llama-swap-cli ps                Show running models
#   llama-swap-cli ps --pretty      Show running models (colored + emoji)
#   llama-swap-cli unload            Unload all models (free VRAM)
#   llama-swap-cli logs [N]          Show recent logs (default: 50 lines)
#
# Output in TTY: aligned columns via `column -t`
# Output in pipe: tab-separated values (TSV) for awk/cut/jq

set -euo pipefail

LLAMA_SWAP_URL="${LLAMA_SWAP_URL:-http://localhost:12434}"
PRETTY="${LLAMA_SWAP_PRETTY:-}"

# Parse flags
ARGS=()
for arg in "$@"; do
  case "$arg" in
    --pretty) PRETTY=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done

# Auto-disable pretty when piping unless FORCE_COLOR
if [[ -n "$PRETTY" ]] && [[ ! -t 1 ]] && [[ -z "${FORCE_COLOR:-}" ]]; then
  PRETTY=""
fi

# Colors
if [[ -n "$PRETTY" ]] && [[ -z "${NO_COLOR:-}" ]]; then
  BOLD='\033[1m' DIM='\033[2m' GREEN='\033[32m' YELLOW='\033[33m'
  CYAN='\033[36m' RED='\033[31m' RESET='\033[0m'
else
  BOLD='' DIM='' GREEN='' YELLOW='' CYAN='' RED='' RESET=''
fi

# Feature tag: pipe-friendly text
feat_tag() {
  local feats="$1" tags=""
  echo "$feats" | grep -qi "thinking" && tags="${tags}+think"
  echo "$feats" | grep -qi "vision"  && tags="${tags}+vision"
  echo "$feats" | grep -qi "tools"   && tags="${tags}+tools"
  tags="${tags#+}"
  [[ -z "$tags" ]] && tags="text"
  echo "$tags"
}

# Feature emoji: pretty output
feat_emoji() {
  local feats="$1" emojis=""
  echo "$feats" | grep -qi "thinking" && emojis="${emojis}🤔"
  echo "$feats" | grep -qi "vision"  && emojis="${emojis}👁"
  echo "$feats" | grep -qi "tools"   && emojis="${emojis}🛠"
  [[ -z "$emojis" ]] && emojis="📝"
  echo "$emojis"
}

# Extract short size: "3.11 GB" from "~3.11 GB (UD-Q3_K_XL ...)" etc.
short_size() {
  echo "$1" | perl -ne 'if (/([\d.]+)\s*(GB|MB|KB)/i) { print "$1 $2" } else { print "-" }'
}

state_label() {
  local state="$1"
  if [[ -n "$PRETTY" ]]; then
    case "$state" in
      ready|started|running|loaded) echo "🟢" ;;
      starting|loading|health_check) echo "🟡" ;;
      stopping|unloading|error|failed) echo "🔴" ;;
      *) echo "⚪" ;;
    esac
  else
    case "$state" in
      ready|started|running|loaded) echo "OK" ;;
      starting|loading|health_check) echo "LOADING" ;;
      stopping|unloading) echo "STOPPING" ;;
      error|failed) echo "ERROR" ;;
      *) echo "$state" ;;
    esac
  fi
}

# Format output: column-aligned in TTY, TSV in pipe
format_output() {
  if [[ -t 1 ]]; then
    column -t -s $'\t'
  else
    cat
  fi
}

cmd_list() {
  local data
  data=$(curl -s "${LLAMA_SWAP_URL}/v1/models" 2>/dev/null)

  if [[ -z "$data" ]] || ! echo "$data" | jq -e '.data' &>/dev/null; then
    echo "Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}" >&2
    echo "Make sure llama-swap is running: systemctl --user status llama-swap" >&2
    exit 1
  fi

  {
    printf "NAME\tSIZE\tTAGS\tDESCRIPTION\n"

    echo "$data" | jq -r '
      .data[] |
      select(.id | endswith(":think") | not) |
      {
        id: .id,
        desc: (.description // ""),
        size: (.meta.llamaswap.size // "-"),
        features: (.meta.llamaswap.features | tostring)
      } | [.id, .features, .desc, .size] | @tsv
    ' | while IFS=$'\t' read -r id features desc size; do
      local tags sz
      if [[ -n "$PRETTY" ]]; then
        tags=$(feat_emoji "$features")
      else
        tags=$(feat_tag "$features")
      fi
      sz=$(short_size "$size")
      printf "${CYAN}%s\t%s\t${DIM}%s${RESET}\t%s\n" "$id" "$sz" "$tags" "$desc"
    done
  } | format_output
}

cmd_ps() {
  local running_data models_data
  running_data=$(curl -s "${LLAMA_SWAP_URL}/running" 2>/dev/null)

  if [[ -z "$running_data" ]]; then
    echo "Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}" >&2
    exit 1
  fi

  local running_count
  running_count=$(echo "$running_data" | jq '.running | length')

  if [[ "$running_count" -eq 0 ]]; then
    if [[ -n "$PRETTY" ]]; then
      echo -e "${YELLOW}No models currently loaded.${RESET}"
    else
      echo "No models currently loaded."
    fi
    echo "Models will load on-demand when you send a request."
    return
  fi

  models_data=$(curl -s "${LLAMA_SWAP_URL}/v1/models" 2>/dev/null)

  {
    printf "NAME\tSTATE\tSIZE\tVRAM\tCONTEXT\tKV_CACHE\tTTL\n"

    echo "$running_data" | jq -r '.running[] | @json' | while IFS= read -r model_json; do
      local id name state proxy ttl
      id=$(echo "$model_json" | jq -r '.model')
      name=$(echo "$model_json" | jq -r '.name')
      state=$(echo "$model_json" | jq -r '.state')
      proxy=$(echo "$model_json" | jq -r '.proxy')
      ttl=$(echo "$model_json" | jq -r '.ttl // 0')

      local icon
      icon=$(state_label "$state")

      # Health check
      local port
      port=$(echo "$proxy" | grep -oP '\d+$' 2>/dev/null || echo "")
      if [[ -n "$port" ]]; then
        local health
        health=$(curl -s "http://localhost:${port}/health" 2>/dev/null || echo "{}")
        local hstatus
        hstatus=$(echo "$health" | jq -r '.status // "unknown"')
        if [[ "$hstatus" != "ok" ]] && [[ "$hstatus" != "loading model" ]]; then
          icon="${icon}(${hstatus})"
        fi
      fi

      # Metadata lookup
      local size="-" vram="-" ctx="-" kv="-"
      if [[ -n "$models_data" ]]; then
        local meta
        meta=$(echo "$models_data" | jq -r --arg id "$id" '
          .data[] | select(.id == $id) |
          .meta.llamaswap // {} | {size, vram_usage, context, kv_cache}
        ' 2>/dev/null)
        if [[ -n "$meta" && "$meta" != "null" ]]; then
          size=$(echo "$meta" | jq -r '.size // "-"')
          vram=$(echo "$meta" | jq -r '.vram_usage // "-"')
          ctx=$(echo "$meta" | jq -r '.context // "-"')
          kv=$(echo "$meta" | jq -r '.kv_cache // "-"')
        fi
      fi

      local sz ttl_display
      sz=$(short_size "$size")
      if [[ "$ttl" -gt 0 ]]; then
        ttl_display="${ttl}s"
      else
        ttl_display="-"
      fi

      printf "${CYAN}%s\t${GREEN}%s${RESET}\t%s\t%s\t%s\t%s\t%s\n" \
        "$name" "$icon" "$sz" "$vram" "$ctx" "$kv" "$ttl_display"
    done
  } | format_output
}

cmd_unload() {
  local result
  result=$(curl -s -o /dev/null -w "%{http_code}" -X POST "${LLAMA_SWAP_URL}/models/unload" 2>/dev/null)

  if [[ "$result" == "200" ]]; then
    echo "All models unloaded. VRAM freed."
  else
    echo "Error: Failed to unload models (HTTP ${result})." >&2
    exit 1
  fi
}

cmd_logs() {
  local lines="${1:-50}"
  journalctl --user -u llama-swap --no-pager -n "$lines"
}

# Main
CMD="${ARGS[0]:-help}"

case "$CMD" in
  list|ls|models)     cmd_list ;;
  ps|running|status)  cmd_ps ;;
  unload|free|eject)  cmd_unload ;;
  logs|log)           cmd_logs "${ARGS[1]:-50}" ;;
  help|--help|-h)
    echo "llama-swap-cli — Manage llama-swap models from the terminal"
    echo ""
    echo "Usage: llama-swap-cli <command> [--pretty]"
    echo ""
    echo "Commands:"
    echo "  list       List configured models"
    echo "  ps         Show running models with stats"
    echo "  unload     Unload all models (free VRAM)"
    echo "  logs [N]   Show recent logs (default: 50 lines)"
    echo ""
    echo "Flags:"
    echo "  --pretty   Colored emoji output (default: plain)"
    echo ""
    echo "Output format:"
    echo "  TTY:  aligned columns (via column -t)"
    echo "  Pipe: tab-separated values (TSV) for awk/cut"
    echo ""
    echo "Environment:"
    echo "  LLAMA_SWAP_URL     llama-swap URL (default: http://localhost:12434)"
    echo "  LLAMA_SWAP_PRETTY=1 Always use pretty output"
    echo "  NO_COLOR=1         Disable colored output"
    echo ""
    echo "Examples:"
    echo "  llama-swap-cli list                      # aligned table"
    echo "  llama-swap-cli list --pretty              # colored + emojis"
    echo "  llama-swap-cli list | cut -f1             # just model names"
    echo "  llama-swap-cli list | awk -F'\\t' '\$3~/vision/' # filter by tag"
    echo "  llama-swap-cli ps | cut -f1,2             # name + state"
    ;;
  *)
    echo "Unknown command: ${CMD}" >&2
    echo "Run 'llama-swap-cli help' for usage." >&2
    exit 1
    ;;
esac