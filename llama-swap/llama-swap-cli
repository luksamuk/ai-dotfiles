#!/usr/bin/env bash
# llama-swap-cli — List and inspect llama-swap models
# Usage:
#   llama-swap-cli list    — Show all configured models (like ollama list)
#   llama-swap-cli ps      — Show running models with stats (like ollama ps)
#   llama-swap-cli unload  — Unload all models (free VRAM)
#   llama-swap-cli logs    — Show recent llama-swap logs

set -euo pipefail

LLAMA_SWAP_URL="${LLAMA_SWAP_URL:-http://localhost:12434}"

# Colors (respected by NO_COLOR env var)
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
  BOLD='\033[1m' DIM='\033[2m' GREEN='\033[32m' YELLOW='\033[33m'
  CYAN='\033[36m' MAGENTA='\033[35m' RED='\033[31m' RESET='\033[0m'
else
  BOLD='' DIM='' GREEN='' YELLOW='' CYAN='' MAGENTA='' RED='' RESET=''
fi

# Calculate visual width of a string (emojis = 2 columns each)
visual_width() {
  local str="$1"
  # Count emojis (Unicode ranges) as 2, everything else as 1
  # First strip ANSI codes
  local clean
  clean=$(echo "$str" | sed $'s/\033\\[[0-9;]*m//g')
  # Count emoji codepoints (rough: CJK, emojis, symbols)
  local emoji_count plain_count
  # Emojis and wide chars: count as 2
  emoji_count=$(echo "$clean" | perl -CSD -ne 'while (/[\x{1F300}-\x{1F9FF}\x{2600}-\x{26FF}\x{2700}-\x{27BF}\x{FE00}-\x{FE0F}\x{1F000}-\x{1FAFF}\x{200D}\x{20E3}\x{E0020}-\x{E007F}\x{2194}-\x{21AA}]/g) { $c++ } END { print $c+0 }')
  # Remove emojis to count narrow chars
  local stripped
  stripped=$(echo "$clean" | perl -CSD -pe 's/[\x{1F300}-\x{1F9FF}\x{2600}-\x{26FF}\x{2700}-\x{27BF}\x{FE00}-\x{FE0F}\x{1F000}-\x{1FAFF}\x{200D}\x{20E3}\x{E0020}-\x{E007F}\x{2194}-\x{21AA}]//g')
  plain_count=${#stripped}
  echo $(( plain_count + emoji_count * 2 ))
}

# Pad string to a visual width, accounting for emojis
pad_to() {
  local str="$1" target_width="$2"
  local vw
  vw=$(visual_width "$str")
  local padding=$(( target_width - vw ))
  if [[ $padding -lt 0 ]]; then padding=0; fi
  printf '%s%*s' "$str" "$padding" ""
}

# Feature emoji mapping
feat_emoji() {
  local feats="$1"
  local emojis=""
  echo "$feats" | grep -qi "thinking" && emojis="${emojis}🤔"
  echo "$feats" | grep -qi "vision" && emojis="${emojis}👁️"
  echo "$feats" | grep -qi "tools" && emojis="${emojis}🛠️"
  [[ -z "$emojis" ]] && emojis="📝"
  echo "$emojis"
}

cmd_list() {
  local data
  data=$(curl -s "${LLAMA_SWAP_URL}/v1/models" 2>/dev/null)

  if [[ -z "$data" ]] || ! echo "$data" | jq -e '.data' &>/dev/null; then
    echo -e "${RED}Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}${RESET}"
    echo "Make sure llama-swap is running: systemctl --user status llama-swap"
    exit 1
  fi

  local count
  count=$(echo "$data" | jq '.data | length')

  echo -e "${BOLD}llama-swap models:${RESET} ${count} configured"
  echo ""

  # Header
  printf "${BOLD}%s${RESET}" "$(pad_to "MODEL" 22)"
  printf "${BOLD}%s${RESET}" "$(pad_to "FLAGS" 8)"
  printf "${BOLD}%s${RESET}" "$(pad_to "DESCRIPTION" 30)"
  printf "${BOLD}%s${RESET}\n" "SIZE"
  printf '%*s' 22 "" | tr ' ' '-'
  printf '%*s' 8 "" | tr ' ' '-'
  printf '%*s' 30 "" | tr ' ' '-'
  printf '%*s\n' 20 "" | tr ' ' '-'

  echo "$data" | jq -r '
    .data[] |
    select(.id | endswith(":think") | not) |
    {
      id: .id,
      desc: (.description // ""),
      size: (.meta.llamaswap.size // "—"),
      features: (.meta.llamaswap.features | tostring)
    } | [.id, .features, .desc, .size] | @tsv
  ' | while IFS=$'\t' read -r id features desc size; do
    local emojis
    emojis=$(feat_emoji "$features")
    # Truncate description for display
    desc=$(echo "$desc" | cut -c1-28)
    printf "${CYAN}%s${RESET}" "$(pad_to "$id" 22)"
    printf '%s' "$(pad_to "$emojis" 8)"
    printf '%s' "$(pad_to "$desc" 30)"
    printf "${DIM}%s${RESET}\n" "$size"
  done

  echo ""
  echo -e "${DIM}  🤔=thinking  👁️=vision  🛠️=tools  📝=text-only${RESET}"
  echo -e "${DIM}  Use '${BOLD}llama-swap-cli ps${RESET}${DIM} to see running models.${RESET}"
}

cmd_ps() {
  local running_data
  running_data=$(curl -s "${LLAMA_SWAP_URL}/running" 2>/dev/null)

  if [[ -z "$running_data" ]]; then
    echo -e "${RED}Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}${RESET}"
    exit 1
  fi

  local running_count
  running_count=$(echo "$running_data" | jq '.running | length')

  if [[ "$running_count" -eq 0 ]]; then
    echo -e "${YELLOW}No models currently loaded.${RESET}"
    echo ""
    echo "Models will load on-demand when you send a request."
    return
  fi

  echo -e "${BOLD}llama-swap running models:${RESET} ${running_count} active"
  echo ""

  echo "$running_data" | jq -r '.running[] | @json' | while IFS= read -r model_json; do
    local id name state proxy ttl desc
    id=$(echo "$model_json" | jq -r '.model')
    name=$(echo "$model_json" | jq -r '.name')
    state=$(echo "$model_json" | jq -r '.state')
    proxy=$(echo "$model_json" | jq -r '.proxy')
    ttl=$(echo "$model_json" | jq -r '.ttl')
    desc=$(echo "$model_json" | jq -r '.description')

    # State icon
    local state_icon state_color
    case "$state" in
      ready|started|running|loaded)  state_icon="🟢"; state_color="$GREEN" ;;
      starting|loading|health_check) state_icon="🟡"; state_color="$YELLOW" ;;
      stopping|unloading|error|failed) state_icon="🔴"; state_color="$RED" ;;
      *)                              state_icon="⚪"; state_color="" ;;
    esac

    echo -e "${BOLD}${state_icon} ${name}${RESET}  ${state_color}(${state})${RESET}"
    echo -e "  ${DIM}ID:${RESET}    ${id}"
    echo -e "  ${DIM}Proxy:${RESET} ${proxy}"

    # Parse port for health check
    local port
    port=$(echo "$proxy" | grep -oP '\d+$' 2>/dev/null || echo "")

    if [[ -n "$port" ]]; then
      local health
      health=$(curl -s "http://localhost:${port}/health" 2>/dev/null || echo "{}")

      local status
      status=$(echo "$health" | jq -r '.status // "unknown"')

      if [[ "$status" == "ok" || "$status" == "loading model" ]]; then
        echo -e "  ${DIM}Status:${RESET} ${GREEN}${status}${RESET}"
      else
        echo -e "  ${DIM}Status:${RESET} ${status}"
      fi

      # Fetch model metadata
      local model_info
      model_info=$(curl -s "${LLAMA_SWAP_URL}/v1/models" 2>/dev/null | \
        jq -r --arg id "$id" '.data[] | select(.id == $id) |
        {size: .meta.llamaswap.size, ctx: .meta.llamaswap.context,
         vram: .meta.llamaswap.vram_usage, kv: .meta.llamaswap.kv_cache,
         features: .meta.llamaswap.features, warning: .meta.llamaswap.warning}' 2>/dev/null)

      if [[ -n "$model_info" && "$model_info" != "null" ]]; then
        local size ctx vram kv warning features
        size=$(echo "$model_info" | jq -r '.size // "—"')
        ctx=$(echo "$model_info" | jq -r '.ctx // "—"')
        vram=$(echo "$model_info" | jq -r '.vram // "—"')
        kv=$(echo "$model_info" | jq -r '.kv // "—"')
        warning=$(echo "$model_info" | jq -r '.warning // ""')
        features=$(echo "$model_info" | jq -r '.features // "{}"')

        local emojis
        emojis=$(feat_emoji "$features")

        echo -e "  ${DIM}Size:${RESET}  ${size}"
        echo -e "  ${DIM}VRAM:${RESET} ${vram}"
        echo -e "  ${DIM}Ctx:${RESET}   ${ctx}"
        echo -e "  ${DIM}KV:${RESET}    ${kv}"
        echo -e "  ${DIM}Flags:${RESET} ${emojis}"

        if [[ -n "$warning" ]]; then
          echo -e "  ${YELLOW}⚠ ${warning}${RESET}"
        fi
      fi
    fi

    # TTL
    if [[ -n "$ttl" && "$ttl" != "null" ]]; then
      local ttl_min
      ttl_min=$((ttl / 60))
      echo -e "  ${DIM}TTL:${RESET}   ${ttl}s (${ttl_min}m idle until unload)"
    fi

    echo ""
  done
}

cmd_unload() {
  echo -e "${YELLOW}Unloading all models...${RESET}"
  local result
  result=$(curl -s -o /dev/null -w "%{http_code}" -X POST "${LLAMA_SWAP_URL}/models/unload" 2>/dev/null)

  if [[ "$result" == "200" ]]; then
    echo -e "${GREEN}✓ All models unloaded. VRAM freed.${RESET}"
  else
    echo -e "${RED}✗ Failed to unload models (HTTP ${result}).${RESET}"
    exit 1
  fi
}

cmd_logs() {
  local lines="${1:-50}"
  journalctl --user -u llama-swap --no-pager -n "$lines"
}

# Main
case "${1:-help}" in
  list|ls|models)  cmd_list ;;
  ps|running|status) cmd_ps ;;
  unload|unload-all|free|eject) cmd_unload ;;
  logs|log) cmd_logs "${2:-50}" ;;
  help|--help|-h)
    echo "llama-swap-cli — Manage llama-swap models from the terminal"
    echo ""
    echo "Usage: llama-swap-cli <command>"
    echo ""
    echo "Commands:"
    echo "  list      List all configured models (like ollama list)"
    echo "  ps        Show running models with stats (like ollama ps)"
    echo "  unload    Unload all models (free VRAM)"
    echo "  logs      Show recent llama-swap logs"
    echo ""
    echo "Environment:"
    echo "  LLAMA_SWAP_URL  llama-swap URL (default: http://localhost:12434)"
    echo "  NO_COLOR        Disable colored output"
    ;;
  *)
    echo -e "${RED}Unknown command: ${1}${RESET}"
    echo "Run 'llama-swap-cli help' for usage."
    exit 1
    ;;
esac