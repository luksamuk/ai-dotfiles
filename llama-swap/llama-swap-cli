#!/usr/bin/env bash
# llama-swap-cli — List and inspect llama-swap models
#
# Usage:
#   llama-swap-cli list              Show configured models (aligned in TTY, TSV in pipe)
#   llama-swap-cli list --pretty     Colored + emoji output
#   llama-swap-cli ps                Show running models (clean, ollama-style)
#   llama-swap-cli ps --pretty      Show running models (colored + emoji)
#   llama-swap-cli ps --legacy      Show running models (old verbose format)
#   llama-swap-cli stats            Detailed metrics for running models
#   llama-swap-cli unload           Unload all models (free VRAM)
#   llama-swap-cli logs [N]         Show recent logs (default: 50 lines)
#
# Output in TTY: aligned columns via `column -t`
# Output in pipe: tab-separated values (TSV) for awk/cut/jq

set -euo pipefail

LLAMA_SWAP_URL="${LLAMA_SWAP_URL:-http://localhost:12434}"
PRETTY="${LLAMA_SWAP_PRETTY:-}"
LEGACY="${LLAMA_SWAP_LEGACY:-}"

# Parse flags
ARGS=()
for arg in "$@"; do
  case "$arg" in
    --pretty) PRETTY=1 ;;
    --legacy) LEGACY=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done

# Auto-disable pretty when piping unless FORCE_COLOR
if [[ -n "$PRETTY" ]] && [[ ! -t 1 ]] && [[ -z "${FORCE_COLOR:-}" ]]; then
  PRETTY=""
fi

# Colors
if [[ -n "$PRETTY" ]] && [[ -z "${NO_COLOR:-}" ]]; then
  BOLD='\033[1m' DIM='\033[2m' GREEN='\033[32m' YELLOW='\033[33m'
  CYAN='\033[36m' RED='\033[31m' RESET='\033[0m'
else
  BOLD='' DIM='' GREEN='' YELLOW='' CYAN='' RED='' RESET=''
fi

# ---- Shared helpers ----

feat_tag() {
  # Ollama-style capabilities: completion, tools, insert, vision, embedding, thinking, image, audio
  local feats="$1" tags=""
  echo "$feats" | grep -qiP '"embedding"\s*:\s*true'    && tags="${tags}+emb"
  echo "$feats" | grep -qiP '"vision"\s*:\s*true'       && tags="${tags}+vis"
  echo "$feats" | grep -qiP '"thinking"\s*:\s*true'    && tags="${tags}+think"
  echo "$feats" | grep -qiP '"tools"\s*:\s*true'        && tags="${tags}+tools"
  echo "$feats" | grep -qiP '"insert"\s*:\s*true'       && tags="${tags}+ins"
  echo "$feats" | grep -qiP '"audio"\s*:\s*true'        && tags="${tags}+audio"
  echo "$feats" | grep -qiP '"image"\s*:\s*true'        && tags="${tags}+img"
  tags="${tags#+}"
  # completion=true and nothing else → chat
  [[ -z "$tags" ]] && tags="chat"
  echo "$tags"
}

feat_emoji() {
  # Ollama-style capabilities → emoji tags
  local feats="$1" emojis=""
  echo "$feats" | grep -qiP '"embedding"\s*:\s*true'    && emojis="${emojis}🔢"
  echo "$feats" | grep -qiP '"vision"\s*:\s*true'       && emojis="${emojis}👁"
  echo "$feats" | grep -qiP '"thinking"\s*:\s*true'    && emojis="${emojis}🤔"
  echo "$feats" | grep -qiP '"tools"\s*:\s*true'        && emojis="${emojis}🛠"
  echo "$feats" | grep -qiP '"insert"\s*:\s*true'       && emojis="${emojis}✏️"
  echo "$feats" | grep -qiP '"audio"\s*:\s*true'        && emojis="${emojis}🔊"
  echo "$feats" | grep -qiP '"image"\s*:\s*true'        && emojis="${emojis}🖼"
  [[ -z "$emojis" ]] && emojis="💬"
  echo "$emojis"
}

# Format parameter count: 4210000000 → 4.21B, 354480000 → 354.48M, 475000000 → 475.00M
short_params() {
  local n="$1"
  if [[ -z "$n" || "$n" == "-" || "$n" == "null" ]]; then echo "-"; return; fi
  if (( n >= 1000000000000 )); then
    awk "BEGIN { printf \"%.2fT\", $n/1000000000000 }" | sed 's/\.00//'
  elif (( n >= 1000000000 )); then
    awk "BEGIN { printf \"%.2fB\", $n/1000000000 }" | sed 's/\.00//'
  elif (( n >= 1000000 )); then
    awk "BEGIN { printf \"%.2fM\", $n/1000000 }" | sed 's/\.00//'
  elif (( n >= 1000 )); then
    awk "BEGIN { printf \"%.2fK\", $n/1000 }" | sed 's/\.00//'
  else
    echo "$n"
  fi
}

# Format context length as power-of-2 K: 262144 → 256K, 131072 → 128K, 512 → 512
short_ctx() {
  local n="$1"
  if [[ -z "$n" || "$n" == "-" || "$n" == "null" ]]; then echo "-"; return; fi
  n=$(( n ))
  if (( n >= 1024 )); then
    awk "BEGIN { printf \"%dK\", $n/1024 }"
  else
    echo "$n"
  fi
}
# Extract short size: "3.11 GB" from "~3.11 GB (UD-Q3_K_XL ...)" etc.
short_size() {
  echo "$1" | perl -ne 'if (/([\d.]+)\s*(GB|MB|KB)/i) { print "$1 $2" } else { print "-" }'
}

# Calculate total disk size from size field, summing mmproj for vision models.
# Input: size="~0.55 GB (Q5_K_M) + 1.1 GB mmproj", vision=true
# Output: "1.7 GB"  (0.55 + 1.1, rounded)
disk_size() {
  local size_raw="$1"
  local vision="$2"
  local total_mb=0

  # Extract all "number UNIT" pairs and sum them in MB
  while IFS= read -r match; do
    local val unit
    val=$(echo "$match" | awk '{print $1}')
    unit=$(echo "$match" | awk '{print $2}')
    case "$unit" in
      TB|tb) total_mb=$(awk "BEGIN {printf \"%.0f\", $total_mb + $val * 1048576}") ;;
      GB|gb) total_mb=$(awk "BEGIN {printf \"%.0f\", $total_mb + $val * 1024}") ;;
      MB|mb) total_mb=$(awk "BEGIN {printf \"%.0f\", $total_mb + $val}") ;;
      KB|kb) total_mb=$(awk "BEGIN {printf \"%.0f\", $total_mb + $val / 1024}") ;;
      *)     total_mb=$(awk "BEGIN {printf \"%.0f\", $total_mb + $val * 1024}") ;;  # assume GB
    esac
  done < <(echo "$size_raw" | perl -ne 'while (/([\d.]+)\s*(TB|GB|MB|KB)/gi) { print "$1 $2\n" }')

  if (( total_mb == 0 )); then
    echo "-"
    return
  fi

  if (( total_mb >= 1024 )); then
    awk "BEGIN { printf \"%.1f GB\", $total_mb / 1024 }" | sed 's/\.0 GB/ GB/'
  else
    echo "${total_mb} MB"
  fi
}

# Extract short context: "1K-131K" from "1K-131K (safe max; 200K works but zero VRAM headroom)" etc.
# Handles both ranges (1K-131K) and single values (32K, 8K)
short_context() {
  echo "$1" | perl -ne '
    if (/^([\d.]+[KMGT]?\s*[-–]\s*[\d.]+[KMGT]?)/i) {
      my $c = $1; $c =~ s/\s//g; print $c;
    } elsif (/^([\d.]+[KMGT])/i) {
      my $c = $1; $c =~ s/\s//g; print $c;
    } else {
      print "-";
    }
  '
}

format_output() {
  if [[ -t 1 ]]; then
    column -t -s $'\t'
  else
    cat
  fi
}

# Fetch llama-swap system Prometheus metrics (cached per call)
_fetch_system_metrics() {
  if [[ -z "${_SYSTEM_METRICS:-}" ]]; then
    _SYSTEM_METRICS=$(curl -s "${LLAMA_SWAP_URL}/metrics" 2>/dev/null || echo "")
  fi
  echo "$_SYSTEM_METRICS"
}

# Fetch model-level metrics from a model's /metrics endpoint
_fetch_model_metrics() {
  local port="$1"
  curl -s "http://localhost:${port}/metrics" 2>/dev/null || echo ""
}

# Extract GPU VRAM usage from system metrics
# Returns: "used_gb / total_gb" or "-"
gpu_vram_summary() {
  local metrics
  metrics=$(_fetch_system_metrics)
  if [[ -z "$metrics" ]]; then
    echo "-"
    return
  fi
  local used_bytes total_bytes
  # Prometheus metrics may have labels before value; value is always last field
  used_bytes=$(echo "$metrics" | grep '^llamaswap_gpu_memory_used_bytes' | awk '{print $NF}' | head -1)
  total_bytes=$(echo "$metrics" | grep '^llamaswap_gpu_memory_total_bytes' | awk '{print $NF}' | head -1)
  if [[ -n "$used_bytes" ]] && [[ -n "$total_bytes" ]]; then
    awk "BEGIN {printf \"%.1f / %.1f GB\", $used_bytes/1073741824, $total_bytes/1073741824}"
  else
    echo "-"
  fi
}

# Extract GPU util% from system metrics
gpu_util() {
  local metrics
  metrics=$(_fetch_system_metrics)
  echo "$metrics" | grep '^llamaswap_gpu_util_percent' | awk '{print $NF}' | head -1 || echo "-"
}

# Extract GPU temp from system metrics
gpu_temp() {
  local metrics
  metrics=$(_fetch_system_metrics)
  echo "$metrics" | grep '^llamaswap_gpu_temperature_celsius' | awk '{print $NF}' | head -1 || echo "-"
}

# Format TTL as countdown
format_ttl() {
  local ttl="$1"
  if [[ "$ttl" -eq 0 ]]; then
    echo "-"
  elif [[ "$ttl" -ge 3600 ]]; then
    awk "BEGIN {printf \"%.1fh\", $ttl/3600}"
  elif [[ "$ttl" -ge 60 ]]; then
    awk "BEGIN {printf \"%.0fm\", $ttl/60}"
  else
    echo "${ttl}s"
  fi
}

# State label (clean, ollama-style)
state_label() {
  local state="$1"
  if [[ -n "$PRETTY" ]]; then
    case "$state" in
      ready|started|running|loaded) echo "🟢" ;;
      starting|loading|health_check) echo "🟡" ;;
      stopping|unloading|error|failed) echo "🔴" ;;
      *) echo "⚪" ;;
    esac
  else
    case "$state" in
      ready|started|running|loaded) echo "running" ;;
      starting|loading|health_check) echo "loading" ;;
      stopping|unloading) echo "stopping" ;;
      error|failed) echo "error" ;;
      *) echo "$state" ;;
    esac
  fi
}

# ---- Commands ----

cmd_describe() {
  local data
  data=$(curl -s "${LLAMA_SWAP_URL}/v1/models" 2>/dev/null)

  if [[ -z "$data" ]] || ! echo "$data" | jq -e '.data' &>/dev/null; then
    echo "Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}" >&2
    echo "Make sure llama-swap is running: systemctl --user status llama-swap" >&2
    exit 1
  fi

  {
    printf "NAME\tDESCRIPTION\n"

    echo "$data" | jq -r '
      .data[] |
      select(.id | endswith(":think") | not) |
      {
        id: .id,
        name: (.name // .id),
        desc: (.description // "-")
      } | [.id, "\(.name) — \(.desc)"] | @tsv
    '
  } | format_output
}

cmd_list() {
  local data
  data=$(curl -s "${LLAMA_SWAP_URL}/v1/models" 2>/dev/null)

  if [[ -z "$data" ]] || ! echo "$data" | jq -e '.data' &>/dev/null; then
    echo "Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}" >&2
    echo "Make sure llama-swap is running: systemctl --user status llama-swap" >&2
    exit 1
  fi

  {
    printf "NAME\tTAGS\tARCH\tPARAMS\tCTX\tEMBED\tQUANT\tSIZE\n"

    echo "$data" | jq -r '
      .data[] |
      select(.id | endswith(":think") | not) |
      {
        id: .id,
        arch: (.meta.llamaswap.architecture // "-"),
        params: (.meta.llamaswap.parameters // "-"),
        ctx: (.meta.llamaswap.context_length // "-"),
        embed: (.meta.llamaswap.embedding_length // "-"),
        quant: (.meta.llamaswap.quantization // "-"),
        size: (.meta.llamaswap.size // "-"),
        features: (.meta.llamaswap.features | tostring),
        vision: (.meta.llamaswap.features.vision // false)
      } | [.id, .arch, (.params | tostring), (.ctx | tostring), (.embed | tostring), .quant, .size, .features, .vision] | @tsv
    ' | while IFS=$'\t' read -r id arch params ctx embed quant size features vision; do
      local tags p c e s
      if [[ -n "$PRETTY" ]]; then
        tags=$(feat_emoji "$features")
      else
        tags=$(feat_tag "$features")
      fi
      p=$(short_params "$params")
      c=$(short_ctx "$ctx")
      e=$(short_ctx "$embed")
      s=$(disk_size "$size" "$vision")
      printf "${CYAN}%s\t${DIM}%s${RESET}\t%s\t%s\t%s\t%s\t%s\t${DIM}%s${RESET}\n" "$id" "$tags" "$arch" "$p" "$c" "$e" "$quant" "$s"
    done
  } | format_output
}

# ---- ps: clean ollama-style output ----

cmd_ps() {
  local running_data
  running_data=$(curl -s "${LLAMA_SWAP_URL}/running" 2>/dev/null)

  if [[ -z "$running_data" ]]; then
    echo "Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}" >&2
    exit 1
  fi

  local running_count
  running_count=$(echo "$running_data" | jq '.running | length')

  if [[ "$running_count" -eq 0 ]]; then
    if [[ -n "$PRETTY" ]]; then
      echo -e "${YELLOW}No models currently loaded.${RESET}"
    else
      echo "No models currently loaded."
    fi
    echo "Models will load on-demand when you send a request."
    return
  fi

  # Fetch model metadata from /v1/models for context/size info
  local models_data
  models_data=$(curl -s "${LLAMA_SWAP_URL}/v1/models" 2>/dev/null || echo '{"data":[]}')

  # Pre-fetch system metrics once
  _SYSTEM_METRICS=$(curl -s "${LLAMA_SWAP_URL}/metrics" 2>/dev/null || echo "")

  local header="NAME\tSIZE\tCONTEXT\tTAGS\tT/S\tUNTIL"
  local output=""

  while IFS= read -r model_json; do
    local id name state ttl port
    id=$(echo "$model_json" | jq -r '.model')
    name=$(echo "$model_json" | jq -r '.name')
    state=$(echo "$model_json" | jq -r '.state')
    proxy=$(echo "$model_json" | jq -r '.proxy')
    ttl=$(echo "$model_json" | jq -r '.ttl // 0')
    port=$(echo "$proxy" | grep -oP '\d+$' 2>/dev/null || echo "")

    # State (clean label)
    local icon
    icon=$(state_label "$state")

    # Features from metadata
    local features="{}" tags=""
    features=$(echo "$models_data" | jq -r --arg id "$id" '.data[] | select(.id == $id) | .meta.llamaswap.features // "{}" | tostring' 2>/dev/null || echo "{}")
    if [[ -n "$PRETTY" ]]; then
      tags=$(feat_emoji "$features")
    else
      tags=$(feat_tag "$features")
    fi

    # Context from metadata (short format)
    local context_raw="-"
    context_raw=$(echo "$models_data" | jq -r --arg id "$id" '.data[] | select(.id == $id) | .meta.llamaswap.context // "-"' 2>/dev/null || echo "-")
    local context
    context=$(short_context "$context_raw")

    # Size from metadata (short format)
    local size="-"
    size=$(echo "$models_data" | jq -r --arg id "$id" '.data[] | select(.id == $id) | .meta.llamaswap.size // "-"' 2>/dev/null)
    size=$(short_size "$size")

    # Throughput from model's Prometheus /metrics
    local gen_tps="-"
    if [[ -n "$port" ]]; then
      local model_metrics
      model_metrics=$(_fetch_model_metrics "$port")
      if [[ -n "$model_metrics" ]]; then
        # llama.cpp metrics
        gen_tps=$(echo "$model_metrics" | grep -P "^llamacpp:predicted_tokens_seconds\s" | awk '{print $2}' || true)
        gen_tps="${gen_tps:-}"
        # vLLM fallback
        if [[ -z "$gen_tps" || "$gen_tps" == "0" ]]; then
          gen_tps=$(echo "$model_metrics" | grep -oP "^vllm:generation_tokens_total\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
          gen_tps="${gen_tps:-}"
        fi
        if [[ -n "$gen_tps" ]] && [[ "$gen_tps" != "0" ]]; then
          gen_tps=$(awk "BEGIN {printf \"%.1f\", $gen_tps}")
        else
          gen_tps="-"
        fi
      fi
    fi

    # TTL formatting
    local ttl_display
    ttl_display=$(format_ttl "$ttl")

    # Build row: NAME  SIZE  CONTEXT  TAGS  T/S  UNTIL
    output+=$(printf "${CYAN}%s${RESET}\t%s\t%s\t${DIM}%s${RESET}\t%s\t%s\n" \
      "$name" "$size" "$context" "$tags" "$gen_tps" "$ttl_display")
  done < <(echo "$running_data" | jq -r '.running[] | @json')

  echo -e "${BOLD}${header}${RESET}\n${output}" | format_output

  # Summary line (ps only)
  if [[ -n "$PRETTY" ]]; then
    local vram gpu_util_val gpu_temp_val
    vram=$(gpu_vram_summary)
    gpu_util_val=$(gpu_util)
    gpu_temp_val=$(gpu_temp)
    echo -e "\n${DIM}GPU: ${vram} | util: ${gpu_util_val}% | temp: ${gpu_temp_val}°C${RESET}"
    echo -e "${DIM}SIZE = model file | T/S = generation throughput | UNTIL = TTL countdown${RESET}"
  fi
}

# ---- ps-legacy: old verbose format ----

cmd_ps_legacy() {
  local running_data
  running_data=$(curl -s "${LLAMA_SWAP_URL}/running" 2>/dev/null)

  if [[ -z "$running_data" ]]; then
    echo "Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}" >&2
    exit 1
  fi

  local running_count
  running_count=$(echo "$running_data" | jq '.running | length')

  if [[ "$running_count" -eq 0 ]]; then
    if [[ -n "$PRETTY" ]]; then
      echo -e "${YELLOW}No models currently loaded.${RESET}"
    else
      echo "No models currently loaded."
    fi
    echo "Models will load on-demand when you send a request."
    return
  fi

  # --- Live VRAM from nvidia-smi ---
  declare -A vram_map
  while IFS=, read -r pid _pName vram_mib; do
    pid="${pid// /}"
    local vram_num
    vram_num=$(echo "$vram_mib" | grep -oP '\d+' | head -1)
    [[ -n "$vram_num" ]] && vram_map["$pid"]="$vram_num"
  done < <(nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv,noheader 2>/dev/null)

  # Total GPU VRAM
  local gpu_total_mib=0 gpu_used_mib=0
  IFS=, read -r gpu_used_mib gpu_total_mib < <(nvidia-smi --query-gpu=memory.used,memory.total --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')
  gpu_total_mib="${gpu_total_mib:-0}"
  gpu_used_mib="${gpu_used_mib:-0}"

  local output=""
  output+="NAME\tPID\tSTATE\tVRAM\tRSS\tT/S\tGPU_LAYERS\tFIT\tTTL\n"

  while IFS= read -r model_json; do
    local id name state proxy ttl port pid
    id=$(echo "$model_json" | jq -r '.model')
    name=$(echo "$model_json" | jq -r '.name')
    state=$(echo "$model_json" | jq -r '.state')
    proxy=$(echo "$model_json" | jq -r '.proxy')
    ttl=$(echo "$model_json" | jq -r '.ttl // 0')

    local icon
    icon=$(state_label "$state")

    # Health check
    port=$(echo "$proxy" | grep -oP '\d+$' 2>/dev/null || echo "")
    if [[ -n "$port" ]]; then
      local health hstatus
      health=$(curl -s "http://localhost:${port}/health" 2>/dev/null || echo "{}")
      if [[ -z "$health" ]]; then
        hstatus="ok"
      else
        hstatus=$(echo "$health" | jq -r '.status // "unknown"' 2>/dev/null || echo "unknown")
        [[ "$hstatus" == "null" || "$hstatus" == "" ]] && hstatus="ok"
      fi
      if [[ "$hstatus" != "ok" ]] && [[ "$hstatus" != "loading model" ]]; then
        icon="${icon}(${hstatus})"
      fi
    fi

    # --- Find PID from port ---
    pid="-"
    if [[ -n "$port" ]]; then
      local found_pid
      found_pid=$(ss -tlnp 2>/dev/null | grep ":${port} " | grep -oP 'pid=\K\d+' | head -1 || true)
      if [[ -z "$found_pid" ]]; then
        found_pid=$(lsof -ti :"$port" 2>/dev/null | head -1 || true)
      fi
      [[ -n "$found_pid" ]] && pid="$found_pid"
    fi

    # --- Live VRAM from nvidia-smi ---
    local vram="-"
    if [[ "$pid" != "-" ]] && [[ -n "${vram_map[$pid]+_}" ]]; then
      local vram_num="${vram_map[$pid]}"
      vram=$(echo "$vram_num" | awk '{printf "%.1f GB", $1/1024}')
    fi

    # --- Live RSS from /proc ---
    local rss="-"
    if [[ "$pid" != "-" ]] && [[ -r "/proc/${pid}/status" ]]; then
      local rss_kb
      rss_kb=$(awk '/^VmRSS:/ {print $2}' "/proc/${pid}/status" 2>/dev/null)
      if [[ -n "$rss_kb" ]]; then
        rss=$(echo "$rss_kb" | awk '{printf "%.1f GB", $1/1048576}')
      fi
    fi

    # --- Parse --fit from cmd ---
    local fit="-"
    local cmd_str
    cmd_str=$(echo "$model_json" | jq -r '.cmd')
    if echo "$cmd_str" | grep -qP '\-\-fit\s'; then
      local backend
      if echo "$cmd_str" | grep -q 'ik_llama.cpp'; then
        backend="ik"
      else
        backend="upstream"
      fi
      local fit_target fit_margin
      fit_target=$(echo "$cmd_str" | grep -oP '\-\-fit-target\s+\K\d+' || echo "")
      fit_margin=$(echo "$cmd_str" | grep -oP '\-\-fit-margin\s+\K\d+' || echo "")
      if [[ -n "$fit_target" ]]; then
        fit="${backend}/${fit_target}MB"
      else
        fit="${backend}/auto"
      fi
      if [[ -n "$fit_margin" ]]; then
        fit="${fit}+${fit_margin}MB"
      fi
    fi

    # --- Live tok/s from /metrics ---
    local gen_tps="-" prompt_tps="-"
    if [[ -n "$port" ]]; then
      local metrics_raw
      metrics_raw=$(curl -s "http://localhost:${port}/metrics" 2>/dev/null || echo "")
      if [[ -n "$metrics_raw" ]]; then
        gen_tps=$(echo "$metrics_raw" | grep -P "^llamacpp:predicted_tokens_seconds\s" | awk '{print $2}' || true)
        gen_tps="${gen_tps:-}"
        prompt_tps=$(echo "$metrics_raw" | grep -P "^llamacpp:prompt_tokens_seconds\s" | awk '{print $2}' || true)
        prompt_tps="${prompt_tps:-}"
        if [[ -z "$gen_tps" || "$gen_tps" == "0" ]]; then
          gen_tps=$(echo "$metrics_raw" | grep -oP "^vllm:generation_tokens_total\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
          gen_tps="${gen_tps:-}"
          prompt_tps=$(echo "$metrics_raw" | grep -oP "^vllm:prompt_tokens_total\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
          prompt_tps="${prompt_tps:-}"
        fi
        [[ -z "$gen_tps" || "$gen_tps" == "0" ]] && gen_tps="-"
        [[ -z "$prompt_tps" || "$prompt_tps" == "0" ]] && prompt_tps="-"
      fi
    fi

    # --- GPU layers from journalctl ---
    local gpu_layers="-"
    if [[ "$pid" != "-" ]]; then
      local layer_info
      layer_info=$(journalctl --user -u llama-swap --since "10 min ago" --no-pager 2>/dev/null \
        | grep -oP "offloaded \K\d+/\d+ layers to GPU" 2>/dev/null | tail -1 || true)
      [[ -n "$layer_info" ]] && gpu_layers="$layer_info"
    fi

    local ttl_display
    if [[ "$ttl" -gt 0 ]]; then
      ttl_display="${ttl}s"
    else
      ttl_display="-"
    fi

    output+=$(printf "${CYAN}%s${RESET}\t%s\t${GREEN}%s${RESET}\t%s\t%s\t%s\t%s\t%s\t%s\n" \
      "$name" "$pid" "$icon" "$vram" "$rss" "$gen_tps" "$gpu_layers" "$fit" "$ttl_display")
  done < <(echo "$running_data" | jq -r '.running[] | @json')

  echo -e "$output" | format_output

  # Summary line
  if [[ -n "$PRETTY" ]]; then
    local total_vram_usage="-"
    local total_used_mib=0
    for pid in "${!vram_map[@]}"; do
      local mib="${vram_map[$pid]}"
      total_used_mib=$((total_used_mib + mib))
    done
    if [[ "$total_used_mib" -gt 0 ]]; then
      total_vram_usage="$(awk 'BEGIN {printf "%.1f / %.1f GB", '"${total_used_mib}"'/1024, '"${gpu_total_mib}"'/1024}')"
    fi
    echo -e "\n${DIM}GPU: ${total_vram_usage}${RESET}"
    echo -e "${DIM}VRAM = GPU memory | RSS = process resident | t/s = generation throughput${RESET}"
  fi
}

cmd_stats() {
  local running_data
  running_data=$(curl -s "${LLAMA_SWAP_URL}/running" 2>/dev/null)

  if [[ -z "$running_data" ]]; then
    echo "Error: Could not reach llama-swap at ${LLAMA_SWAP_URL}" >&2
    exit 1
  fi

  local running_count
  running_count=$(echo "$running_data" | jq '.running | length')

  if [[ "$running_count" -eq 0 ]]; then
    echo "No models currently loaded. No stats available."
    return
  fi

  echo "$running_data" | jq -r '.running[] | @json' | while IFS= read -r model_json; do
    local id name proxy port
    id=$(echo "$model_json" | jq -r '.model')
    name=$(echo "$model_json" | jq -r '.name')
    proxy=$(echo "$model_json" | jq -r '.proxy')
    port=$(echo "$proxy" | grep -oP '\d+$' 2>/dev/null || echo "")

    if [[ -z "$port" ]]; then
      echo "=== $name === (no port)"
      continue
    fi

    local metrics_raw
    metrics_raw=$(curl -s "http://localhost:${port}/metrics" 2>/dev/null || echo "")

    if [[ -z "$metrics_raw" ]]; then
      echo "=== $name === (metrics not available — need --metrics flag)"
      continue
    fi

    # Parse Prometheus metrics (llama.cpp + vLLM fallback)
    prompt_total=$(echo "$metrics_raw" | grep "^llamacpp:prompt_tokens_total" | awk "{print \$2}" || true)
    gen_total=$(echo "$metrics_raw" | grep "^llamacpp:tokens_predicted_total" | awk "{print \$2}" || true)
    prompt_sec=$(echo "$metrics_raw" | grep "^llamacpp:prompt_seconds_total" | awk "{print \$2}" || true)
    gen_sec=$(echo "$metrics_raw" | grep "^llamacpp:tokens_predicted_seconds_total" | awk "{print \$2}" || true)
    processing=$(echo "$metrics_raw" | grep "^llamacpp:requests_processing" | awk "{print \$2}" || true)
    deferred=$(echo "$metrics_raw" | grep "^llamacpp:requests_deferred" | awk "{print \$2}" || true)
    # vLLM fallback
    if [[ -z "$prompt_total" ]]; then
      prompt_total=$(echo "$metrics_raw" | grep -oP "^vllm:prompt_tokens_total\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
      gen_total=$(echo "$metrics_raw" | grep -oP "^vllm:generation_tokens_total\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
      prompt_sec=$(echo "$metrics_raw" | grep -oP "^vllm:e2e_request_latency_seconds_sum\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
      gen_sec=$(echo "$metrics_raw" | grep -oP "^vllm:request_inference_time_seconds_sum\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
      processing=$(echo "$metrics_raw" | grep -oP "^vllm:num_requests_running\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
      deferred=$(echo "$metrics_raw" | grep -oP "^vllm:num_requests_waiting\{[^}]*\}\s+\K[0-9.]+" | head -1 || true)
    fi
    # Compute average speeds
    local avg_prompt_tps="0" avg_gen_tps="0"
    if [[ -n "$prompt_sec" ]] && [[ "$(echo "$prompt_sec > 0" | bc -l 2>/dev/null || echo 0)" == "1" ]]; then
      avg_prompt_tps=$(awk "BEGIN {printf \"%.1f\", ${prompt_total:-0} / ${prompt_sec}}")
    fi
    if [[ -n "$gen_sec" ]] && [[ "$(echo "$gen_sec > 0" | bc -l 2>/dev/null || echo 0)" == "1" ]]; then
      avg_gen_tps=$(awk "BEGIN {printf \"%.1f\", ${gen_total:-0} / ${gen_sec}}")
    fi

    if [[ -n "$PRETTY" ]]; then
      echo -e "\n${CYAN}${BOLD}=== ${name} ===${RESET}"
      echo -e "  ${GREEN}Tokens:${RESET}  ${prompt_total:--} in → ${gen_total:--} out"
      echo -e "  ${GREEN}Speed:${RESET}   prompt ${avg_prompt_tps} t/s | generation ${avg_gen_tps} t/s"
      echo -e "  ${GREEN}Time:${RESET}    prompt ${prompt_sec:--}s | generation ${gen_sec:--}s"
      echo -e "  ${GREEN}Queue:${RESET}  ${processing:-0} processing | ${deferred:-0} deferred"
    else
      echo "=== $name ==="
      echo "  prompt_tokens: ${prompt_total:--}"
      echo "  completion_tokens: ${gen_total:--}"
      echo "  avg_prompt_t/s: ${avg_prompt_tps}"
      echo "  avg_gen_t/s: ${avg_gen_tps}"
      echo "  prompt_time_s: ${prompt_sec:--}"
      echo "  gen_time_s: ${gen_sec:--}"
      echo "  requests_processing: ${processing:-0}"
      echo "  requests_deferred: ${deferred:-0}"
    fi
  done
}

cmd_unload() {
  local target="${ARGS[1]:-}"
  local endpoint result

  if [[ -n "$target" ]]; then
    endpoint="${LLAMA_SWAP_URL}/api/models/unload/${target}"
  else
    endpoint="${LLAMA_SWAP_URL}/api/models/unload"
  fi

  result=$(curl -s -o /dev/null -w "%{http_code}" -X POST "$endpoint" 2>/dev/null)

  if [[ "$result" == "200" ]]; then
    if [[ -n "$target" ]]; then
      echo "Model '${target}' unloaded."
    else
      echo "All models unloaded. VRAM freed."
    fi
  else
    echo "Error: Failed to unload ${target:-all models} (HTTP ${result})." >&2
    exit 1
  fi
}

cmd_logs() {
  local lines="${1:-50}"
  journalctl --user -u llama-swap --no-pager -n "$lines"
}

cmd_testchat() {
  local testchat_dir="$(dirname "$(readlink -f "$0")")/testchat"
  if [[ ! -d "$testchat_dir" ]]; then
    testchat_dir="$HOME/.config/llama-swap/testchat"
  fi

  if [[ ! -f "$testchat_dir/main.py" ]]; then
    echo "Error: testchat not found. Looked in:" >&2
    echo "  $(dirname "$(readlink -f "$0")")/testchat/" >&2
    echo "  $HOME/.config/llama-swap/testchat/" >&2
    exit 1
  fi

  export LLAMA_SWAP_HOST="${LLAMA_SWAP_HOST:-127.0.0.1}"
  export LLAMA_SWAP_PORT="${LLAMA_SWAP_PORT:-12434}"
  local chat_args=("$@")

  if [[ -x "$testchat_dir/.venv/bin/python" ]]; then
    exec "$testchat_dir/.venv/bin/python" "$testchat_dir/main.py" "${chat_args[@]}"
  else
    exec uv run --project "$testchat_dir" "$testchat_dir/main.py" "${chat_args[@]}"
  fi
}

cmd_voiceclone() {
  local tui_dir="$HOME/projects/ai/voiceclone-tui"
  local venv_python="$tui_dir/.venv/bin/python"

  if [[ ! -f "$tui_dir/voice_tui.py" ]]; then
    echo "Error: voiceclone-tui not found at $tui_dir/voice_tui.py" >&2
    echo "Install: git clone or copy voiceclone-tui to $tui_dir" >&2
    exit 1
  fi

  if [[ ! -x "$venv_python" ]]; then
    echo "Error: voiceclone venv not found at $venv_python" >&2
    echo "The TUI will offer to create it on first run." >&2
    echo "Or run manually: python3 -m venv $tui_dir/.venv" >&2
    exit 1
  fi

  exec "$venv_python" "$tui_dir/voice_tui.py" "$@"
}

cmd_worldsim() {
  local worldsim_dir="$(dirname "$(readlink -f "$0")")/worldsim"
  if [[ ! -d "$worldsim_dir" ]]; then
    worldsim_dir="$HOME/.config/llama-swap/worldsim"
