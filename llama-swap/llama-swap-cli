# Main
CMD="${ARGS[0]:-help}"

case "$CMD" in
  describe|desc)       cmd_describe ;;
  list|ls|models)     cmd_list ;;
  ps|running|status)
    if [[ -n "$LEGACY" ]]; then
      cmd_ps_legacy
    else
      cmd_ps
    fi
    ;;
  stats|metrics)      cmd_stats ;;
  unload|free|eject)  cmd_unload "${ARGS[@]:1}" ;;
  logs|log)           cmd_logs "${ARGS[1]:-50}" ;;
  testchat|chat)      cmd_testchat "${ARGS[@]:1}" ;;
  worldsim|sim|ws)   cmd_worldsim "${ARGS[@]:1}" ;;
  voiceclone|voice|vc) cmd_voiceclone "${ARGS[@]:1}" ;;
  help|--help|-h)
    echo "llama-swap-cli — Manage llama-swap models from the terminal"
    echo ""
    echo "Usage: llama-swap-cli <command> [--pretty] [--legacy]"
    echo ""
    echo "Commands:"
    echo "  list              List configured models"
    echo "  describe          Show model name + description"
    echo "  ps                Show running models (clean ollama-style format)"
    echo "  ps --legacy       Show running models (old verbose format)"
    echo "  stats             Detailed metrics for running models"
    echo "  unload [MODEL]    Unload all models, or a specific model"
    echo "  logs [N]          Show recent logs (default: 50 lines)"
    echo "  testchat          Open interactive chat with model selection"
    echo "  worldsim          Interactive web world model simulation"
    echo "  voiceclone        Open voice clone TUI"
    echo ""
    echo "Flags:"
    echo "  --pretty   Colored emoji output (default: plain)"
    echo "  --legacy   Use old verbose ps format (with PID, VRAM, RSS, etc.)"
    echo ""
    echo "Output format:"
    echo "  TTY:  aligned columns (via column -t)"
    echo "  Pipe: tab-separated values (TSV) for awk/cut"
    echo ""
    echo "Environment:"
    echo "  LLAMA_SWAP_URL     llama-swap URL (default: http://localhost:12434)"
    echo "  LLAMA_SWAP_PRETTY=1 Always use pretty output"
    echo "  LLAMA_SWAP_LEGACY=1 Always use legacy ps format"
    echo "  NO_COLOR=1         Disable colored output"
    echo ""
    echo "Examples:"
    echo "  llama-swap-cli list                      # aligned table"
    echo "  llama-swap-cli list --pretty              # colored + emojis"
    echo "  llama-swap-cli list | cut -f1             # just model names"
    echo '  llama-swap-cli list | awk -F"\t" '"'"'$3~/vision/'"'"' # filter by tag'
    echo "  llama-swap-cli ps                        # clean view (SIZE, CONTEXT, T/S, UNTIL)"
    echo "  llama-swap-cli ps --legacy                # old view (PID, VRAM, RSS, GPU_LAYERS, FIT)"
    echo "  llama-swap-cli stats                      # detailed metrics per model"
    echo "  llama-swap-cli unload                     # unload all models"
    echo "  llama-swap-cli unload qwen3.6-35b-a3b     # unload specific model"
    ;;
  *)
    echo "Unknown command: ${CMD}" >&2
    echo "Run 'llama-swap-cli help' for usage." >&2
    exit 1
    ;;
esac