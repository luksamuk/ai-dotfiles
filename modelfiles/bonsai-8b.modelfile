# Bonsai-8B - PrismML tool-calling model
# Based on Qwen3-8B architecture with PrismML optimizations
# Chat template includes full tool/function calling support
# Size: ~5GB | Capabilities: completion, tools
#
# Larger variant with better reasoning while maintaining tool capabilities
# Good for more complex agentic workflows

FROM hf.co/prism-ml/Bonsai-8B-gguf:Q4_K_M

# Context window - Qwen3 supports long contexts
PARAMETER num_ctx 65536

# Generation params - manufacturer recommended
PARAMETER temperature 0.7
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER repeat_penalty 1.05