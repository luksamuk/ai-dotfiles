FROM gemma4:e4b

# Gemma 4 Effective 4B - larger model with native tool calling
# 9.6GB, runs on CPU for 6GB GPU, 131K context

# Context (131K max, 32K practical for 6GB GPU with CPU offload)
PARAMETER num_ctx 32768

# Sampling - balanced for tool calling
PARAMETER temperature 0.7
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER repeat_penalty 1.1

# Gemma 4 supports native function calling
# Tested Apr 2026: works correctly with ask-ai tools (~4min response)