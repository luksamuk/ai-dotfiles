FROM huihui_ai/gemma-4-abliterated:e4b
# Gemma 4 Abliterated Effective 4B - uncensored, native tool calling + vision
# 9.6GB, 128K context, Text + Image input
# Abliterated: reduced safety filtering, use temperature 0.7-0.8 max

# Context (128K max, 32K practical for local use)
PARAMETER num_ctx 32768

# Sampling - tempered for abliterated model (avoid hallucination)
PARAMETER temperature 0.7
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER min_p 0.01
PARAMETER repeat_penalty 1.1