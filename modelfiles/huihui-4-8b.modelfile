FROM huihui_ai/huihui-4:8b
# Huihui4-8B-A4B - Pruned MoE from Gemma 4 26B-A4B-it (32/128 experts, 8 active)
# 8B total params, 4B active per token | ~5GB Q4_K_M | completion, tools, vision
# Not abliterated — standard Gemma 4 template with native FC support

# Context (128K max, 32K practical for local MoE)
PARAMETER num_ctx 32768

# Sampling - balanced for MoE stability
PARAMETER temperature 0.7
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER min_p 0.01
PARAMETER repeat_penalty 1.05