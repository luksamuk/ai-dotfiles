# Bonsai-4B - PrismML compact tool-calling model
# Based on Qwen3-4B architecture with PrismML optimizations
# Chat template includes full tool/function calling support
# Size: ~2.5GB | Capabilities: completion, tools
#
# PrismML trained this specifically for function calling
# Great balance between size and capability

FROM hf.co/prism-ml/Bonsai-4B-gguf

# Context window - Qwen3 supports long contexts
PARAMETER num_ctx 65536

# Generation params - manufacturer recommended
PARAMETER temperature 0.7
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER repeat_penalty 1.05