# DeepSeek-R1-7B - DeepSeek reasoning model with tool support
# Excellent for complex reasoning tasks combined with tools
# Features: Chain-of-thought + function calling
# Size: ~4.5GB | Capabilities: completion, tools, reasoning
#
# DeepSeek R1 series combines strong reasoning with tool capabilities
# Good for tasks requiring multi-step logic

FROM deepseek-r1:7b

# Context window
PARAMETER num_ctx 65536

# Generation params - lower temp for reasoning accuracy
PARAMETER temperature 0.5
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER repeat_penalty 1.05