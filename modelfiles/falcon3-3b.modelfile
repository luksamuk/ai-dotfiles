# Falcon3-3B-Instruct - TII's latest Falcon 3 series
# From Technology Innovation Institute (UAE)
#
# Features:
# - 3B parameters (~2GB in Q4_K_M)
# - Multilingual: EN, FR, ES, PT
# - Good instruct following
# - Falcon architecture

FROM hf.co/tiiuae/Falcon3-3B-Instruct-GGUF:Q4_K_M

# Context window
PARAMETER num_ctx 32768

# Generation params
PARAMETER temperature 0.7
PARAMETER top_p 0.95
PARAMETER top_k 40
PARAMETER min_p 0.01
PARAMETER repeat_penalty 1.05